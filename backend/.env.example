# Supabase API keys (found in your Supabase project → Settings → API)
PUBLIC_KEY=your_supabase_publishable_key_here
SECRET_KEY=your_supabase_secret_key_here

# PostgreSQL connection details (found in Supabase → Settings → Database → Connection string)
user=postgres.your_project_ref
password=your_database_password
host=your_db_host.pooler.supabase.com
port=6543
dbname=postgres

# Google AI API key (get one at https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your_google_ai_api_key_here
